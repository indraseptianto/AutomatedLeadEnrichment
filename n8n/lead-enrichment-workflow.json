      "id": "Set_Normalize_Lead",
      "name": "Set - Normalize Lead",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [520, -80]
    },
    {
      "parameters": {
        "jsCode": "const lead = $json;\nconst company = (lead.company || '').toLowerCase();\n\nlet companySize = 'Unknown';\nlet linkedinUrl = null;\nlet industry = 'General';\n\nif (company.includes('acme')) {\n  companySize = '51-200';\n  linkedinUrl = 'https://www.linkedin.com/company/acme';\n  industry = 'Technology';\n} else if (company.includes('global')) {\n  companySize = '201-500';\n  linkedinUrl = 'https://www.linkedin.com/company/global';\n  industry = 'Enterprise Services';\n} else if (company.includes('studio')) {\n  companySize = '1-10';\n  linkedinUrl = 'https://www.linkedin.com/search/results/companies/?keywords=' + encodeURIComponent(lead.company);\n  industry = 'Creative Services';\n} else {\n  companySize = '11-50';\n  linkedinUrl = 'https://www.linkedin.com/search/results/companies/?keywords=' + encodeURIComponent(lead.company);\n}\n\nreturn [{\n  json: {\n    ...lead,\n    company_size: companySize,\n    company_linkedin_url: linkedinUrl,\n    industry,\n    enrichment_status: 'mock_enriched'\n  }\n}];"
      },
      "id": "Code_Mock_Company_Enrichment",
      "name": "Code - Mock Company Enrichment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, -80]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LARAVEL_API_URL || 'http://localhost:8000/api/leads' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/json"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-Automation-Token",
              "value": "={{ $env.AUTOMATION_TOKEN || 'demo-secret-token' }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"name\": $json.name,\n  \"email\": $json.email,\n  \"company\": $json.company,\n  \"message\": $json.message,\n  \"source\": $json.source,\n  \"company_size\": $json.company_size,\n  \"company_linkedin_url\": $json.company_linkedin_url,\n  \"industry\": $json.industry,\n  \"enrichment_status\": $json.enrichment_status,\n  \"received_at\": $json.received_at\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false,
              "neverError": true
            }
          },
          "timeout": 10000
        }
      },
      "id": "HTTP_Save_Lead_To_Laravel",
      "name": "HTTP - Save Lead to Laravel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1080, -80],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "or",
          "conditions": [
            {
              "id": "success_true",
              "leftValue": "={{ $json.success }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            },
            {
              "id": "lead_id_exists",
              "leftValue": "={{ $json.lead_id }}",
              "rightValue": "",
              "operator": { "type": "number", "operation": "exists" }
            }
          ]
        }
      },
