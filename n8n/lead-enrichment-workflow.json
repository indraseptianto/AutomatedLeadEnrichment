        "text": "={{ 'Hi ' + $('Set - Normalize Lead').item.json.name + ',\\n\\nThanks for reaching out to us.\\n\\nWe received your enquiry from ' + $('Set - Normalize Lead').item.json.company + ' and our team will review it shortly.\\n\\nBest regards,\\nBusiness Automation Team' }}",
