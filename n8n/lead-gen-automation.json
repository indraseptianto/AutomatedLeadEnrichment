    {
      "parameters": {
        "url": "https://serpapi.com/search",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "engine",
              "value": "google_maps"
            },
            {
              "name": "q",
              "value": "={{ $json.company ? $json.company + ' ' + $json.location : $json.name }}"
            },
            {
              "name": "type",
              "value": "search"
            },
            {
              "name": "num",
              "value": "3"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        896,
        0
      ],
      "id": "serpapi-enrich",
      "name": "SerpAPI Company Enrichment"
    },
    {
      "parameters": {
        "jsCode": "// Process SerpAPI enrichment results\nconst item = $input.first().json;\n\nconst result = {\n  ...item,\n  enrichment: {\n    enriched_at: new Date().toISOString(),\n    source: 'SerpAPI Google Maps',\n  }\n};\n\n// Check if SerpAPI returned results\nconst results = item.local_results || [];\nif (results.length > 0) {\n  const first = results[0];\n  result.enrichment.company_name = first.title || item.company;\n  result.enrichment.address = first.address || '';\n  result.enrichment.phone = first.phone || item.phone;\n  result.enrichment.website = first.website || item.website;\n  result.enrichment.rating = first.rating || 0;\n  result.enrichment.reviews = first.reviews || 0;\n  result.enrichment.type = first.type || '';\n  result.enrichment.status = 'enriched';\n\n  // Boost score if we found data\n  if (first.website) result.initial_score += 10;\n  if (first.phone) result.initial_score += 5;\n  if (first.rating && first.rating > 4) result.initial_score += 10;\n} else {\n  result.enrichment.status = 'not_found';\n  result.enrichment.note = 'No Google Maps listing found for this company';\n}\n\nresult.final_score = Math.min(result.initial_score, 100);\n\n// Lead score classification\nif (result.final_score >= 70) result.lead_quality = 'hot';\nelse if (result.final_score >= 40) result.lead_quality = 'warm';\nelse result.lead_quality = 'cold';\n\nreturn [{ json: result }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        0
      ],
      "id": "process-enrich",
      "name": "Process Enrichment"
    },
