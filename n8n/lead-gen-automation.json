    {
      "parameters": {
        "jsCode": "// Normalize incoming lead payload\nconst item = $input.first().json;\nconst body = item.body || item;\n\n// Map aliases\nconst lead = {\n  name: body.name || body.fullName || body.full_name || '',\n  email: body.email || '',\n  phone: body.phone || body.phoneNumber || body.mobile || '',\n  company: body.company || body.business || body.company_name || '',\n  website: body.website || body.url || '',\n  source: body.source || 'webhook',\n  message: body.message || body.notes || body.description || '',\n  industry: body.industry || '',\n  location: body.location || body.city || body.country || '',\n};\n\n// Validation\nconst errors = [];\nif (!lead.name) errors.push('name is required');\nif (!lead.email && !lead.phone) errors.push('email or phone is required');\n\n// Assign score points\nlet score = 0;\nif (lead.name) score += 10;\nif (lead.email) score += 15;\nif (lead.phone) score += 10;\nif (lead.company) score += 15;\nif (lead.website) score += 10;\nif (lead.message) score += 5;\n\nlead.initial_score = score;\nlead.errors = errors;\nlead.valid = errors.length === 0;\nlead.received_at = new Date().toISOString();\n\nreturn [{ json: lead }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "id": "normalize-lead",
      "name": "Normalize & Validate"
    },
