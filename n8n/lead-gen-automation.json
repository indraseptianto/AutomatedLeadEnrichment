            },
            {
              "name": "notes",
              "value": "={{ '[Automated Lead Gen] Score: ' + $json.final_score + '/100 - Quality: ' + $json.lead_quality + ' | Message: ' + ($json.message || 'No message') }}"
            },
            {
              "name": "status",
              "value": "={{ $json.lead_quality === 'hot' ? 'new' : 'new' }}"
            }
          ]
        },
        "options": {
          "timeout": 10000,
          "allowUnauthorizedCerts": true
        }
